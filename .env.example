# Resend (envío de formulario de contacto)
# https://resend.com/api-keys
RESEND_API_KEY=

# Remitente (debe ser dominio verificado en Resend)
# Si no existe el dominio aún, dejar el default ADAF <noreply@resend.dev> y verificar después
RESEND_FROM=ADAF <contacto@adafsolucionesfiscales.com>

# Destinatario del formulario de contacto (correo de la oficina)
RESEND_TO=juridicoadaf@gmail.com

# Override opcional del sitio (default: https://adafsolucionesfiscales.com)
# NEXT_PUBLIC_SITE_URL=
