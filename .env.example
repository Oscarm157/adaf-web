# Resend (envío de formulario de contacto)
# https://resend.com/api-keys
RESEND_API_KEY=

# Remitente (debe ser dominio verificado en Resend antes de live)
# Mientras no se verifica adafsolucionesfiscales.com, usar el sandbox de Resend:
#   RESEND_FROM=ADAF <onboarding@resend.dev>
# Una vez verificado el dominio, sustituir por:
#   RESEND_FROM=ADAF <contacto@adafsolucionesfiscales.com>
RESEND_FROM=ADAF <onboarding@resend.dev>

# Destinatario del formulario de contacto (correo de la oficina)
RESEND_TO=juridicoadaf@gmail.com

# Override opcional del sitio (default: https://adafsolucionesfiscales.com)
# NEXT_PUBLIC_SITE_URL=

# Calendly del despacho (opcional). Si se define, los CTAs de "Agenda tu
# valoración" / "Agendar 20 minutos" apuntan a esta URL. Si queda vacía,
# los CTAs caen al flujo actual (formulario + WhatsApp).
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/<usuario>/<evento>

# Replicate — pipeline de imágenes editoriales (npm run img:flow)
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
